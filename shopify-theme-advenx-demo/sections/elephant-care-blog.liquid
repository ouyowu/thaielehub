{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-article-card.css' | asset_url | stylesheet_tag }}
{{ 'elephant-care-blog-v2.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- paginate blog.articles by section.settings.posts_per_page -%}
  <section class="elephant-care-shell color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
    <div class="page-width">
      <p class="elephant-care-kicker">{{ section.settings.kicker }}</p>
      <h1 class="elephant-care-heading">{{ blog.title | escape }}</h1>
      <p class="elephant-care-lead">
        {%- if blog.articles_count > 0 and blog.description != blank -%}
          {{ blog.description | replace: 'Living Green', 'Thaielehub' | replace: 'Big Boy', 'Thaielehub' }}
        {%- else -%}
          {{ section.settings.intro }}
        {%- endif -%}
      </p>

      <div class="elephant-care-grid">
        {%- for article in blog.articles -%}
          {%- assign fallback_card_image = 'elehub-selected-033.jpg' -%}
          {%- if article.handle contains 'bangkok' or article.handle contains 'pattaya' -%}
            {%- assign fallback_card_image = 'elehub-selected-044.jpg' -%}
          {%- elsif article.handle contains 'kids' or article.handle contains 'rainy-season' -%}
            {%- assign fallback_card_image = 'elehub-selected-054.jpg' -%}
          {%- elsif article.handle contains 'ethical' or article.handle contains 'bathing' or article.handle contains 'touching' -%}
            {%- assign fallback_card_image = 'elehub-selected-061.jpg' -%}
          {%- elsif article.handle contains 'faq' or article.handle contains 'best-elephant' -%}
            {%- assign fallback_card_image = 'elehub-selected-092.jpg' -%}
          {%- endif -%}
          <article class="elephant-care-card{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
            <a class="elephant-care-card__media" href="{{ article.url }}?view=elephant-care">
              {%- if article.image -%}
                <img
                  class="elephant-care-card__image"
                  srcset="
                    {%- if article.image.width >= 600 -%}{{ article.image | image_url: width: 600 }} 600w,{%- endif -%}
                    {%- if article.image.width >= 900 -%}{{ article.image | image_url: width: 900 }} 900w,{%- endif -%}
                    {%- if article.image.width >= 1200 -%}{{ article.image | image_url: width: 1200 }} 1200w,{%- endif -%}
                    {{ article.image | image_url }} {{ article.image.width }}w
                  "
                  sizes="(min-width: 990px) calc((100vw - 9.6rem) / 3), (min-width: 750px) calc((100vw - 6rem) / 2), calc(100vw - 4rem)"
                  src="{{ article.image | image_url: width: 900 }}"
                  alt="{{ article.image.alt | default: article.title | replace: 'Living Green', 'Thaielehub' | replace: 'Big Boy', 'Thaielehub' | escape }}"
                  loading="lazy"
                  width="{{ article.image.width }}"
                  height="{{ article.image.height }}"
                >
              {%- else -%}
                <img
                  class="elephant-care-card__image"
                  src="{{ fallback_card_image | asset_url }}"
                  alt="{{ article.title | replace: 'Living Green', 'Thaielehub' | replace: 'Big Boy', 'Thaielehub' | escape }}"
                  loading="lazy"
                  width="900"
                  height="675"
                >
              {%- endif -%}
            </a>

            <div class="elephant-care-card__content">
              <div class="elephant-care-card__meta">
                <span>{{ article.published_at | date: '%b %d, %Y' }}</span>
                <span class="elephant-care-card__meta-dot"></span>
                <span>{{ section.settings.meta_label }}</span>
              </div>

              <h2 class="elephant-care-card__title">
                <a href="{{ article.url }}?view=elephant-care">{{ article.title | replace: 'Living Green', 'Thaielehub' | replace: 'Big Boy', 'Thaielehub' | escape }}</a>
              </h2>

              <p class="elephant-care-card__excerpt">
                {%- if article.excerpt != blank -%}
                  {{ article.excerpt | replace: 'Living Green', 'Thaielehub' | replace: 'Big Boy', 'Thaielehub' | strip_html | truncatewords: 22 }}
                {%- else -%}
                  {{ article.content | replace: 'Living Green', 'Thaielehub' | replace: 'Big Boy', 'Thaielehub' | strip_html | truncatewords: 22 }}
                {%- endif -%}
              </p>

              <span class="elephant-care-card__cta">
                {{ section.settings.read_more_label }}
                <span class="svg-wrapper">{{- 'icon-arrow.svg' | inline_asset_content -}}</span>
              </span>
            </div>
          </article>
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <div class="element-margin-top">
          {%- render 'pagination', paginate: paginate -%}
        </div>
      {%- endif -%}
    </div>
  </section>
{%- endpaginate -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Blog",
  "@id": "{{ shop.url }}{{ blog.url }}#blog",
  "name": {{ blog.title | json }},
  "url": "{{ shop.url }}{{ blog.url }}",
  "description": "Thaielehub elephant sanctuary travel guides for Chiang Mai, Bangkok and Pattaya, covering welfare-first choices, hotel pickup, itinerary planning and first-time visitor questions.",
  "publisher": {
    "@type": "TravelAgency",
    "@id": "{{ shop.url }}/#organization",
    "name": "Thaielehub",
    "url": "{{ shop.url }}"
  }
}
</script>

{% schema %}
{
  "name": "Elephant care blog",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Elephant Care & Welfare Blog"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro copy",
      "default": "Field notes, ethical travel guidance, and conservation stories for guests who want to understand Thailand's elephant welfare landscape before they book."
    },
    {
      "type": "text",
      "id": "meta_label",
      "label": "Meta label",
      "default": "Insider field guide"
    },
    {
      "type": "text",
      "id": "read_more_label",
      "label": "Read more label",
      "default": "Read the full guide"
    },
    {
      "type": "range",
      "id": "posts_per_page",
      "min": 3,
      "max": 12,
      "step": 3,
      "default": 6,
      "label": "Posts per page"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 72
    }
  ]
}
{% endschema %}
