{%- liquid
  assign og_title = page_title | default: shop.name
  assign og_url = canonical_url | default: request.origin
  assign og_type = 'website'
  assign og_description = page_description | default: shop.description | default: shop.name
  assign og_title = og_title | replace: 'Living Green', 'Thaielehub' | replace: 'Big Boy', 'Thaielehub'
  assign og_description = og_description | replace: 'Living Green', 'Thaielehub' | replace: 'Big Boy', 'Thaielehub'
  assign og_description_normalized = og_description | strip | downcase

  if og_description_normalized == 'thaielehub'
    assign og_description = 'Book ethical elephant sanctuary tours in Thailand with ThaiEleHub. Compare Chiang Mai, Bangkok and Pattaya departures with no riding, no shows and clear hotel pickup.'
  endif

  if request.page_type == 'product'
    assign og_type = 'product'
  elsif request.page_type == 'article'
    assign og_type = 'article'
  elsif request.page_type == 'password'
    assign og_url = request.origin
  endif
%}

<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:url" content="{{ og_url }}">
<meta property="og:title" content="{{ og_title | escape }}">
<meta property="og:type" content="{{ og_type }}">
<meta property="og:description" content="{% if og_description contains 'ThaiEleHub' and og_description.size < 20 %}Book ethical elephant sanctuary tours in Thailand with ThaiEleHub. Compare Chiang Mai, Bangkok and Pattaya departures with no riding, no shows and clear hotel pickup.{% else %}{{ og_description | escape }}{% endif %}">

{%- if page_image -%}
  <meta property="og:image" content="http:{{ page_image | image_url }}">
  <meta property="og:image:secure_url" content="https:{{ page_image | image_url }}">
  <meta property="og:image:width" content="{{ page_image.width }}">
  <meta property="og:image:height" content="{{ page_image.height }}">
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <meta property="og:price:amount" content="{{ product.price | money_without_currency | strip_html }}">
  <meta property="og:price:currency" content="{{ cart.currency.iso_code }}">
{%- endif -%}

{%- if settings.social_twitter_link != blank -%}
  <meta name="twitter:site" content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' }}">
{%- endif -%}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ og_title | escape }}">
<meta name="twitter:description" content="{% if og_description contains 'ThaiEleHub' and og_description.size < 20 %}Book ethical elephant sanctuary tours in Thailand with ThaiEleHub. Compare Chiang Mai, Bangkok and Pattaya departures with no riding, no shows and clear hotel pickup.{% else %}{{ og_description | escape }}{% endif %}">
