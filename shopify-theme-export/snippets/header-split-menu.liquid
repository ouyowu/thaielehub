{% comment %}
  ThaiEleHub desktop split navigation.
  Keeps the primary menu visually balanced around the centered logo.
{% endcomment %}

<nav class="header__split-menu header__split-menu--{{ side }}" aria-label="{{ 'sections.header.menu' | t }}">
  <ul class="list-menu list-menu--inline" role="list">
    {%- if side == 'left' -%}
      <li>
        <header-menu>
          <details id="Details-SplitHeaderMenu-tours">
            <summary id="SplitHeaderMenu-tours" class="header__menu-item list-menu__item link focus-inset">
              <span>Tours</span>
              {{- 'icon-caret.svg' | inline_asset_content -}}
            </summary>
            <ul
              id="SplitHeaderMenu-MenuList-tours"
              class="header__submenu list-menu list-menu--disclosure color-{{ section.settings.menu_color_scheme }} gradient caption-large motion-reduce global-settings-popup"
              role="list"
              tabindex="-1"
            >
              <li><a href="/?tour-region=cm#tours" class="header__menu-item list-menu__item link link--text focus-inset caption-large">Chiang Mai Tours</a></li>
              <li><a href="/?tour-region=bk#tours" class="header__menu-item list-menu__item link link--text focus-inset caption-large">From Bangkok</a></li>
              <li><a href="/?tour-region=pt#tours" class="header__menu-item list-menu__item link link--text focus-inset caption-large">From Pattaya</a></li>
            </ul>
          </details>
        </header-menu>
      </li>
      <li><a href="/#camps" class="header__menu-item list-menu__item link link--text focus-inset"><span>Our Camps</span></a></li>
      <li><a href="/#story" class="header__menu-item list-menu__item link link--text focus-inset"><span>Our Story</span></a></li>
    {%- else -%}
      <li><a href="/#ethics" class="header__menu-item list-menu__item link link--text focus-inset"><span>Ethics</span></a></li>
      <li><a href="/blogs/elephant-sanctuary-thailand-guides" class="header__menu-item list-menu__item link link--text focus-inset"><span>Journal</span></a></li>
      <li><a href="/#faq" class="header__menu-item list-menu__item link link--text focus-inset"><span>FAQ</span></a></li>
    {%- endif -%}
  </ul>
</nav>
