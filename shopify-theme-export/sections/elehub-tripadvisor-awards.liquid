<section class="elehub-tripadvisor-awards-section" aria-label="Tripadvisor Travelers' Choice awards">
  <style>
    .elehub-tripadvisor-awards-section,
    .elehub-tripadvisor-awards-section * { box-sizing: border-box; }
    .elehub-tripadvisor-awards-section { padding: 82px 40px; background: #1a1a1a; color: #fff; }
    .elehub-tripadvisor-awards-section__inner { display: grid; max-width: 1280px; margin: 0 auto; grid-template-columns: minmax(260px, .78fr) minmax(0, 1.22fr); gap: 46px; align-items: center; }
    .elehub-tripadvisor-awards-section__copy span { display: block; margin-bottom: 12px; color: rgba(200,169,110,.86); font-size: 10px; font-weight: 600; letter-spacing: .28em; text-transform: uppercase; }
    .elehub-tripadvisor-awards-section__copy h2 { margin: 0; color: #fff; font-family: Georgia, "Times New Roman", Times, serif; font-size: clamp(32px, 4vw, 50px); font-weight: 600; letter-spacing: -.03em; line-height: 1.08; }
    .elehub-tripadvisor-awards-section__copy h2 em { font-style: italic; }
    .elehub-tripadvisor-awards-section__copy p { max-width: 520px; margin: 18px 0 0; color: rgba(255,255,255,.62); font-family: Georgia, "Times New Roman", Times, serif; font-size: 15px; line-height: 1.78; }
    .elehub-tripadvisor-awards-section__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; }
    .elehub-tripadvisor-awards-section__grid a { display: flex; min-height: 178px; align-items: center; justify-content: center; padding: 18px; border: 1px solid rgba(200,169,110,.22); background: rgba(255,255,255,.045); transition: transform .28s ease, background .28s ease, border-color .28s ease; }
    .elehub-tripadvisor-awards-section__grid a:hover { border-color: rgba(200,169,110,.58); background: rgba(255,255,255,.08); transform: translateY(-5px); }
    .elehub-tripadvisor-awards-section__grid img { width: min(148px, 100%); height: auto; object-fit: contain; }
    @media (max-width: 900px) {
      .elehub-tripadvisor-awards-section { padding: 66px 20px; }
      .elehub-tripadvisor-awards-section__inner { grid-template-columns: 1fr; gap: 30px; }
      .elehub-tripadvisor-awards-section__grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
      .elehub-tripadvisor-awards-section__grid a { min-height: 150px; padding: 14px; }
    }
  </style>
  <div class="elehub-tripadvisor-awards-section__inner">
    <div class="elehub-tripadvisor-awards-section__copy">
      <span>Tripadvisor Recognition</span>
      <h2>Trusted by travelers,<br><em>year after year.</em></h2>
      <p>LivingGreen Elephant Sanctuary has received Tripadvisor Travelers' Choice recognition across 2023, 2024, 2025 and 2026, reflecting consistent guest satisfaction and ethical elephant encounters in Chiang Mai.</p>
    </div>
    <div class="elehub-tripadvisor-awards-section__grid">
      <a target="_blank" rel="noopener" href="https://www.tripadvisor.com/Attraction_Review-g293917-d23935719-Reviews-Living_Green_Elephant_Sanctuary-Chiang_Mai.html">
        <img src="{{ 'tripadvisor-travelers-choice-2026.png' | asset_url }}" alt="Tripadvisor Travelers' Choice 2026 award for LivingGreen Elephant Sanctuary" width="180" height="180" loading="lazy">
      </a>
      <a target="_blank" rel="noopener" href="https://www.tripadvisor.com/Attraction_Review-g293917-d23935719-Reviews-Living_Green_Elephant_Sanctuary-Chiang_Mai.html">
        <img src="{{ 'tripadvisor-travelers-choice-2025.png' | asset_url }}" alt="Tripadvisor Travelers' Choice 2025 award for LivingGreen Elephant Sanctuary" width="180" height="180" loading="lazy">
      </a>
      <a target="_blank" rel="noopener" href="https://www.tripadvisor.com/Attraction_Review-g293917-d23935719-Reviews-Living_Green_Elephant_Sanctuary-Chiang_Mai.html">
        <img src="{{ 'tripadvisor-travelers-choice-2024.png' | asset_url }}" alt="Tripadvisor Travelers' Choice 2024 award for LivingGreen Elephant Sanctuary" width="180" height="180" loading="lazy">
      </a>
      <a target="_blank" rel="noopener" href="https://www.tripadvisor.com/Attraction_Review-g293917-d23935719-Reviews-Living_Green_Elephant_Sanctuary-Chiang_Mai.html">
        <img src="{{ 'tripadvisor-travelers-choice-2023.png' | asset_url }}" alt="Tripadvisor Travelers' Choice 2023 award for LivingGreen Elephant Sanctuary" width="180" height="180" loading="lazy">
      </a>
    </div>
  </div>
</section>

