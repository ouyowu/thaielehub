<style>
/* ── TOKENS ── */
:root{
  --black:#111;--dark:#1a1a1a;--mid:#555;--muted:#888;
  --border:#e0e0e0;--bg:#f7f5f2;--warm:#f2ede8;--white:#fff;
  --green:#2D5016;--gdeep:#1E3A0F;--gmid:#3D6B20;
  --gold:#C8A96E;--gold2:#dfc49a;
  --serif:Georgia,"Times New Roman",Times,serif;
  --sans:Georgia,"Times New Roman",Times,serif;
  --ease:cubic-bezier(.25,.1,.25,1);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{font-size:16px;scroll-behavior:smooth}
body{font-family:var(--sans);color:var(--dark);background:var(--white);overflow-x:hidden;line-height:1.6}
.shopify-section-group-header-group,.shopify-section-group-footer-group{display:none!important}
img{display:block;max-width:100%;height:100%;object-fit:cover}
a{text-decoration:none;color:inherit}
ul{list-style:none}
button{cursor:pointer;border:none;background:none;font-family:inherit}

/* ── ANNOUNCE BAR ── */
.announce{background:var(--dark);color:rgba(255,255,255,.8);font-family:var(--sans);font-size:11px;font-weight:400;letter-spacing:.12em;text-transform:uppercase;text-align:center;padding:10px 20px}
.announce a{color:rgba(255,255,255,.8);border-bottom:1px solid rgba(255,255,255,.3);padding-bottom:1px;transition:color .2s}
.announce a:hover{color:#fff}

/* ── NAV ── */
.nav-wrap{position:sticky;top:0;z-index:100;background:var(--white);border-bottom:1px solid var(--border)}
.nav{display:grid;grid-template-columns:1fr auto 1fr;align-items:center;height:60px;padding:0 40px;max-width:100%}
.nav-left{display:flex;align-items:center;gap:28px}
.nav-left a{font-family:var(--sans);font-size:11px;font-weight:500;letter-spacing:.18em;text-transform:uppercase;color:var(--dark);transition:color .2s}
.nav-left a:hover{color:var(--muted)}
.nav-logo{text-align:center;font-family:var(--sans);font-size:13px;font-weight:500;letter-spacing:.36em;text-transform:uppercase;color:var(--dark);white-space:nowrap}
.nav-right{display:flex;align-items:center;justify-content:flex-end;gap:18px}
.nav-icon{display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--dark);transition:color .2s}
.nav-icon:hover{color:var(--muted)}
.nav-icon svg{width:18px;height:18px;stroke:currentColor;fill:none;stroke-width:1.5}
.nav-hamburger{display:none;flex-direction:column;gap:5px;padding:2px}
.nav-hamburger span{display:block;width:20px;height:1.5px;background:var(--dark);transition:all .3s}

/* ── DRAWER ── */
.drawer{position:fixed;top:0;right:0;width:300px;height:100vh;background:var(--white);z-index:999;transform:translateX(100%);transition:transform .4s var(--ease);border-left:1px solid var(--border);padding:60px 36px;display:flex;flex-direction:column;gap:24px}
.drawer.open{transform:translateX(0)}
.drawer-close{position:absolute;top:20px;right:22px;font-size:22px;color:var(--dark);cursor:pointer}
.drawer a{font-family:var(--sans);font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--dark);font-weight:500;border-bottom:1px solid var(--border);padding-bottom:18px}
.drawer-overlay{position:fixed;inset:0;background:rgba(0,0,0,.3);z-index:998;opacity:0;pointer-events:none;transition:opacity .4s}
.drawer-overlay.open{opacity:1;pointer-events:all}

/* ── HERO ── */
.hero{position:relative;height:calc(100vh - 60px);min-height:580px;overflow:hidden}
.slide{position:absolute;inset:0;opacity:0;transition:opacity 1s var(--ease)}
.slide.active{opacity:1}
.slide-img{position:absolute;inset:0;width:100%;height:100%}
.slide-img img{width:100%;height:100%;object-fit:cover;object-position:center}
.slide-overlay{position:absolute;inset:0;background:linear-gradient(90deg,rgba(0,0,0,.55) 0%,rgba(0,0,0,.22) 55%,rgba(0,0,0,.04) 100%)}
.slide-content{position:absolute;bottom:14%;left:7%;z-index:2;max-width:540px}
.slide-label{font-family:var(--sans);font-size:10px;font-weight:500;letter-spacing:.3em;text-transform:uppercase;color:rgba(255,255,255,.72);margin-bottom:16px}
.slide-title{font-family:var(--serif);font-size:clamp(48px,6.5vw,80px);font-weight:400;color:#fff;line-height:1.07;letter-spacing:-.01em;margin-bottom:26px}
.slide-title em{font-style:italic}
.slide-btns{display:flex;gap:12px;flex-wrap:wrap}
.btn-ghost{display:inline-block;padding:13px 28px;border:1px solid rgba(255,255,255,.85);color:#fff;font-family:var(--sans);font-size:10px;font-weight:500;letter-spacing:.22em;text-transform:uppercase;border-radius:0;background:transparent;transition:background .25s,color .25s;cursor:pointer}
.btn-ghost:hover{background:#fff;color:var(--dark)}
.btn-ghost-dark{border-color:var(--dark);color:var(--dark)}
.btn-ghost-dark:hover{background:var(--dark);color:#fff}
.btn-ghost-green{border-color:var(--green);color:var(--green)}
.btn-ghost-green:hover{background:var(--green);color:#fff}
.slide-dots{position:absolute;bottom:26px;left:50%;transform:translateX(-50%);display:flex;gap:8px;z-index:10}
.dot{width:28px;height:1.5px;background:rgba(255,255,255,.32);cursor:pointer;transition:background .3s}
.dot.active{background:#fff}

/* ── STATS BAND ── */
.stats-band{background:var(--gdeep);display:grid;grid-template-columns:repeat(4,1fr)}
.stat-item{padding:40px 20px;text-align:center;border-right:1px solid rgba(255,255,255,.1)}
.stat-item:last-child{border-right:none}
.stat-num{font-family:var(--serif);font-size:42px;font-weight:400;color:var(--gold);line-height:1;margin-bottom:8px}
.stat-label{font-family:var(--sans);font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,.5)}

/* ── SECTIONS ── */
.section{padding:88px 40px}
.section-inner{max-width:1280px;margin:0 auto}
.sec-label{font-family:var(--sans);font-size:10px;font-weight:500;letter-spacing:.28em;text-transform:uppercase;color:var(--muted);margin-bottom:12px;display:block}
.sec-title{font-family:var(--serif);font-size:clamp(32px,4vw,50px);font-weight:500;color:var(--dark);line-height:1.12;letter-spacing:-.01em}
.sec-title em{font-style:italic}
.sec-body{font-family:var(--sans);font-size:15px;font-weight:400;color:var(--mid);line-height:1.85;max-width:480px}
.sec-rule{width:36px;height:1px;background:var(--dark);margin:22px 0}

/* ── CAMPS ── */
.camps-section{background:var(--white)}
.camps-header{text-align:center;margin-bottom:44px}
.camps-header .sec-rule{margin:18px auto}
.camps-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px}
.camp-card{position:relative;aspect-ratio:3/4;overflow:hidden;cursor:pointer}
.camp-card img{width:100%;height:100%;object-fit:cover;transition:transform .7s var(--ease)}
.camp-card:hover img{transform:scale(1.06)}
.camp-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.68) 0%,rgba(0,0,0,.12) 55%,transparent 100%);display:flex;flex-direction:column;justify-content:flex-end;padding:26px 22px;transition:background .4s}
.camp-card:hover .camp-overlay{background:linear-gradient(to top,rgba(0,0,0,.78) 0%,rgba(0,0,0,.22) 60%,transparent 100%)}
.camp-lbl{font-family:var(--sans);font-size:9px;letter-spacing:.22em;text-transform:uppercase;color:rgba(255,255,255,.65);margin-bottom:5px}
.camp-name{font-family:var(--serif);font-size:24px;font-weight:400;color:#fff;margin-bottom:3px}
.camp-dist{font-family:var(--sans);font-size:11px;color:rgba(255,255,255,.55);letter-spacing:.06em;margin-bottom:14px}
.camp-link{font-family:var(--sans);font-size:10px;font-weight:500;letter-spacing:.2em;text-transform:uppercase;color:#fff;border-bottom:1px solid rgba(255,255,255,.45);padding-bottom:2px;display:inline-block;transition:border-color .2s}
.camp-card:hover .camp-link{border-color:#fff}

/* ── TOURS ── */
.tours-section{background:var(--bg)}
.tours-header{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:44px;flex-wrap:wrap;gap:20px}
.tab-group{display:flex;gap:0;border:1px solid var(--border)}
.tab-btn{font-family:var(--sans);font-size:10px;font-weight:500;letter-spacing:.16em;text-transform:uppercase;padding:10px 20px;color:var(--muted);background:transparent;border-right:1px solid var(--border);transition:all .2s;white-space:nowrap}
.tab-btn:last-child{border-right:none}
.tab-btn:hover{color:var(--dark);background:rgba(0,0,0,.03)}
.tab-btn.active{background:var(--dark);color:#fff}
.tour-panel{display:none}
.tour-panel.active{display:block}
.tours-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px}
.tour-card{background:var(--white);cursor:pointer;transition:box-shadow .3s var(--ease)}
.tour-card:hover{box-shadow:0 8px 40px rgba(0,0,0,.09)}
.tour-img{position:relative;aspect-ratio:4/5;overflow:hidden}
.tour-img img{width:100%;height:100%;object-fit:cover;transition:transform .6s var(--ease)}
.tour-card:hover .tour-img img{transform:scale(1.05)}
.tour-badge{position:absolute;top:12px;left:12px;background:var(--dark);color:#fff;font-family:var(--sans);font-size:9px;letter-spacing:.16em;text-transform:uppercase;padding:4px 10px;z-index:2}
.tour-info{padding:18px 18px 20px}
.tour-cat{font-family:var(--sans);font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);margin-bottom:5px}
.tour-name{font-family:var(--serif);font-size:18px;font-weight:500;color:var(--dark);line-height:1.3;margin-bottom:10px}
.tour-desc{font-family:var(--sans);font-size:12px;font-weight:400;color:var(--mid);line-height:1.7;margin-bottom:12px}
.tour-includes{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:14px}
.tour-incl{font-family:var(--sans);font-size:10px;color:var(--mid);background:var(--bg);padding:3px 9px;letter-spacing:.04em}
.tour-foot{display:flex;align-items:center;justify-content:space-between;padding-top:12px;border-top:1px solid var(--border)}
.tour-price{font-family:var(--serif);font-size:20px;font-weight:400;color:var(--dark)}
.tour-price span{font-family:var(--sans);font-size:11px;color:var(--muted);font-weight:400}
.tour-dur{font-family:var(--sans);font-size:10px;letter-spacing:.08em;color:var(--muted);text-transform:uppercase}
.tour-book{display:block;width:100%;text-align:center;padding:11px;border:1px solid var(--dark);font-family:var(--sans);font-size:10px;font-weight:500;letter-spacing:.2em;text-transform:uppercase;color:var(--dark);border-radius:0;background:transparent;margin-top:12px;transition:all .25s;cursor:pointer}
.tour-book:hover{background:var(--dark);color:#fff}
.pickup-note{margin-top:28px;padding:18px 22px;border:1px solid var(--border);background:var(--white);font-family:var(--sans);font-size:12px;color:var(--mid);line-height:1.8}
.pickup-note strong{color:var(--dark);font-weight:600}

/* ── EDITORIAL SPLIT ── */
.editorial{background:var(--white)}
.editorial-grid{display:grid;grid-template-columns:1fr 1fr;min-height:580px}
.editorial-img{overflow:hidden}
.editorial-img img{width:100%;height:100%;object-fit:cover;min-height:520px;transition:transform .7s var(--ease)}
.editorial-img:hover img{transform:scale(1.03)}
.editorial-text{display:flex;flex-direction:column;justify-content:center;padding:72px 60px}
.editorial-text .sec-body{margin-top:18px}
.editorial-grid.rev .editorial-img{order:2}
.editorial-grid.rev .editorial-text{order:1}

/* ── BABY ELEPHANT FEATURE ── */
.baby-section{background:var(--gdeep)}
.baby-grid{display:grid;grid-template-columns:1fr 1fr;min-height:480px}
.baby-img{overflow:hidden}
.baby-img img{width:100%;height:100%;object-fit:cover;min-height:420px}
.baby-text{display:flex;flex-direction:column;justify-content:center;padding:72px 60px}
.baby-section .sec-label{color:var(--gold);opacity:.8}
.baby-section .sec-title{color:#fff}
.baby-section .sec-body{color:rgba(255,255,255,.65);max-width:100%}
.baby-section .sec-rule{background:var(--gold);opacity:.5}

/* ── ETHICS ── */
.ethics-section{background:var(--warm)}
.ethics-header{text-align:center;margin-bottom:52px}
.ethics-header .sec-rule{margin:18px auto}
.ethics-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border)}
.ethics-item{background:var(--warm);padding:40px 32px;transition:background .3s}
.ethics-item:hover{background:var(--white)}
.ethics-icon{font-size:18px;margin-bottom:18px;display:block;font-style:normal}
.ethics-name{font-family:var(--serif);font-size:19px;font-weight:500;color:var(--dark);margin-bottom:8px}
.ethics-text{font-family:var(--sans);font-size:13px;font-weight:400;color:var(--mid);line-height:1.82}

/* ── HOW IT WORKS ── */
.how-section{background:var(--white)}
.how-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:0;border:1px solid var(--border);margin-top:52px}
.how-step{padding:40px 28px;border-right:1px solid var(--border)}
.how-step:last-child{border-right:none}
.how-num{font-family:var(--serif);font-size:40px;font-weight:400;color:var(--border);line-height:1;margin-bottom:18px}
.how-title{font-family:var(--serif);font-size:17px;font-weight:500;color:var(--dark);margin-bottom:8px}
.how-text{font-family:var(--sans);font-size:13px;font-weight:400;color:var(--mid);line-height:1.82}

/* ── AWARDS ── */
.awards-section{background:var(--dark);color:#fff;padding:82px 40px}
.awards-inner{max-width:1280px;margin:0 auto;display:grid;grid-template-columns:minmax(260px,.8fr) minmax(0,1.2fr);gap:46px;align-items:center}
.awards-copy .sec-label{color:rgba(200,169,110,.86)}
.awards-copy .sec-title{color:#fff}
.awards-copy .sec-body{color:rgba(255,255,255,.58);margin-top:18px}
.awards-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}
.award-card{display:flex;min-height:178px;align-items:center;justify-content:center;padding:18px;border:1px solid rgba(200,169,110,.22);background:rgba(255,255,255,.045);transition:transform .28s var(--ease),background .28s var(--ease),border-color .28s var(--ease)}
.award-card:hover{transform:translateY(-5px);border-color:rgba(200,169,110,.58);background:rgba(255,255,255,.08)}
.award-card img{width:min(148px,100%);height:auto;object-fit:contain}

/* ── TESTIMONIALS ── */
.testi-section{background:var(--bg)}
.testi-header{text-align:center;margin-bottom:52px}
.testi-header .sec-rule{margin:18px auto}
.testi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:2px;background:var(--border)}
.testi-item{background:var(--white);padding:40px 32px}
.testi-stars{font-size:13px;color:var(--gold);letter-spacing:3px;margin-bottom:18px}
.testi-text{font-family:var(--serif);font-size:17px;font-weight:400;font-style:italic;color:var(--dark);line-height:1.7;margin-bottom:22px}
.testi-rule{width:28px;height:1px;background:var(--border);margin-bottom:14px}
.testi-name{font-family:var(--sans);font-size:11px;font-weight:500;letter-spacing:.16em;text-transform:uppercase;color:var(--dark)}
.testi-origin{font-family:var(--sans);font-size:11px;color:var(--muted);margin-top:3px}

/* ── FAQ ── */
.faq-section{background:var(--warm)}
.faq-grid{display:grid;grid-template-columns:1fr 1fr;gap:0;border:1px solid var(--border);margin-top:48px}
.faq-item{background:var(--white);border-right:1px solid var(--border);border-bottom:1px solid var(--border)}
.faq-item:nth-child(even){border-right:none}
.faq-item:nth-last-child(-n+2){border-bottom:none}
.faq-q{width:100%;text-align:left;padding:20px 24px;display:flex;align-items:center;justify-content:space-between;gap:16px;font-family:var(--sans);font-size:13px;font-weight:500;letter-spacing:.03em;color:var(--dark);cursor:pointer;background:none;transition:background .2s}
.faq-q:hover{background:var(--bg)}
.faq-icon{font-size:20px;font-weight:400;color:var(--muted);flex-shrink:0;transition:transform .3s;line-height:1}
.faq-item.open .faq-icon{transform:rotate(45deg)}
.faq-body{max-height:0;overflow:hidden;transition:max-height .4s ease}
.faq-item.open .faq-body{max-height:240px}
.faq-body-inner{padding:0 24px 20px;font-family:var(--sans);font-size:13px;font-weight:400;color:var(--mid);line-height:1.85}

/* ── BOOKING CTA ── */
.booking-section{background:var(--dark);padding:96px 40px;text-align:center}
.booking-inner{max-width:620px;margin:0 auto}
.bk-label{font-family:var(--sans);font-size:10px;font-weight:500;letter-spacing:.28em;text-transform:uppercase;color:rgba(255,255,255,.45);margin-bottom:18px}
.bk-title{font-family:var(--serif);font-size:clamp(36px,5vw,56px);font-weight:400;color:#fff;line-height:1.12;margin-bottom:14px}
.bk-title em{font-style:italic}
.bk-sub{font-family:var(--sans);font-size:13px;font-weight:400;color:rgba(255,255,255,.5);letter-spacing:.05em;margin-bottom:44px;line-height:1.75}
.bk-btns{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;margin-bottom:36px}
.btn-wa{display:inline-flex;align-items:center;gap:9px;padding:14px 30px;background:#25D366;color:#fff;font-family:var(--sans);font-size:10px;font-weight:500;letter-spacing:.2em;text-transform:uppercase;border-radius:0;border:1px solid #25D366;transition:all .25s}
.btn-wa:hover{background:transparent;color:#25D366}
.bk-perks{display:flex;gap:28px;justify-content:center;flex-wrap:wrap}
.bk-perk{font-family:var(--sans);font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.32);display:flex;align-items:center;gap:6px}

/* ── FOOTER ── */
.footer{background:var(--dark);padding:68px 40px 36px}
.footer-inner{max-width:1280px;margin:0 auto}
.footer-top{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:44px;padding-bottom:52px;border-bottom:1px solid rgba(255,255,255,.1);margin-bottom:28px}
.footer-logo{font-family:var(--sans);font-size:11px;font-weight:500;letter-spacing:.34em;text-transform:uppercase;color:#fff;margin-bottom:18px}
.footer-logo span{display:block;font-size:10px;font-weight:400;letter-spacing:.16em;color:var(--gold);margin-top:4px;text-transform:uppercase}
.footer-about{font-family:var(--sans);font-size:13px;font-weight:400;color:rgba(255,255,255,.42);line-height:1.85;margin-bottom:24px;max-width:260px}
.footer-socials{display:flex;gap:14px}
.footer-soc{font-family:var(--sans);font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.42);transition:color .2s;cursor:pointer}
.footer-soc:hover{color:#fff}
.footer-col h4{font-family:var(--sans);font-size:10px;font-weight:500;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,.42);margin-bottom:18px}
.footer-col ul{display:flex;flex-direction:column;gap:10px}
.footer-col ul li a{font-family:var(--sans);font-size:13px;font-weight:400;color:rgba(255,255,255,.6);transition:color .2s}
.footer-col ul li a:hover{color:#fff}
.footer-bottom{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px}
.footer-copy{font-family:var(--sans);font-size:11px;color:rgba(255,255,255,.26);letter-spacing:.04em}
.footer-legal{display:flex;gap:22px}
.footer-legal a{font-family:var(--sans);font-size:11px;color:rgba(255,255,255,.26);transition:color .2s}
.footer-legal a:hover{color:rgba(255,255,255,.6)}

/* ── FAB ── */
.fab{position:fixed;bottom:28px;right:28px;z-index:500;display:flex;flex-direction:column;align-items:flex-end;gap:10px}
.fab-main{width:52px;height:52px;background:#25D366;display:flex;align-items:center;justify-content:center;font-size:22px;cursor:pointer;box-shadow:0 4px 20px rgba(37,211,102,.4);transition:transform .25s,box-shadow .25s;border-radius:0}
.fab-main:hover{transform:translateY(-3px);box-shadow:0 8px 28px rgba(37,211,102,.5)}
.fab-panel{display:none;flex-direction:column;gap:8px;align-items:flex-end}
.fab.open .fab-panel{display:flex}
.fab-item{display:flex;align-items:center;gap:8px}
.fab-lbl{font-family:var(--sans);font-size:10px;letter-spacing:.14em;text-transform:uppercase;background:var(--dark);color:#fff;padding:7px 14px;white-space:nowrap;box-shadow:0 2px 10px rgba(0,0,0,.2)}
.fab-ico{width:42px;height:42px;display:flex;align-items:center;justify-content:center;font-size:18px;box-shadow:0 2px 10px rgba(0,0,0,.15);cursor:pointer}
.fab-ico.wa{background:#25D366}
.fab-ico.em{background:var(--gold)}

/* ── REVEAL ── */
.reveal{opacity:0;transform:translateY(26px);transition:opacity .72s,transform .72s}
.reveal.in{opacity:1;transform:none}
.d1{transition-delay:.1s}.d2{transition-delay:.2s}.d3{transition-delay:.3s}.d4{transition-delay:.4s}

/* ── RESPONSIVE ── */
@media(max-width:1100px){
  .editorial-grid,.editorial-grid.rev{grid-template-columns:1fr}
