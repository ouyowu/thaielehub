<script>
  (() => {
    const input = document.querySelector('#SymVariant-{{ section.id }}');
    const hotelInput = document.querySelector('#SymHotel-{{ section.id }}');
    const hotelField = document.querySelector('#SymHotelField-{{ section.id }}');
    const pickupOptions = document.querySelectorAll('[data-sym-pickup-option]');
    const guestNameInput = document.querySelector('#SymName-{{ section.id }}');
    const tourDateInput = document.querySelector('#SymDate-{{ section.id }}');
    const summaryName = document.querySelector('#SymSummaryName-{{ section.id }}');
    const summaryDate = document.querySelector('#SymSummaryDate-{{ section.id }}');
    const summaryHotel = document.querySelector('#SymSummaryHotel-{{ section.id }}');
    document.querySelectorAll('input[name="sym_variant_{{ section.id }}"]').forEach((radio) => {
      radio.addEventListener('change', () => { if (radio.checked && input) input.value = radio.value; });
    });
    const updateBookingSummary = () => {
      const meetingPointSelected = document.querySelector('[data-sym-pickup-option="meeting"]')?.checked;
      if (summaryName) summaryName.textContent = guestNameInput?.value.trim() || 'Add your name';
      if (summaryDate) summaryDate.textContent = tourDateInput?.value || 'Choose a tour date';
      if (summaryHotel) summaryHotel.textContent = meetingPointSelected ? 'Ekkamai Bus Terminal meeting point' : (hotelInput?.value.trim() || 'Add your hotel or address');
    };
    const updatePickupOption = () => {
      const meetingPointSelected = document.querySelector('[data-sym-pickup-option="meeting"]')?.checked;
      if (hotelField && hotelInput) {
        hotelField.hidden = meetingPointSelected;
        hotelInput.required = !meetingPointSelected;
        if (meetingPointSelected) hotelInput.value = '';
      }
      updateBookingSummary();
    };
    [guestNameInput, tourDateInput, hotelInput].forEach((field) => field?.addEventListener('input', updateBookingSummary));
    pickupOptions.forEach((option) => option.addEventListener('change', updatePickupOption));
    if (tourDateInput) tourDateInput.min = new Date().toISOString().split('T')[0];
    updatePickupOption();
    updateBookingSummary();

  })();
</script>

<script type="application/ld+json">
